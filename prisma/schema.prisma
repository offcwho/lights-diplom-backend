// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum ProductColor {
  white_ivory
  architectural_grey
  carbon_black
  olive_green
}

enum OrderStatus {
  cancelled
  new
  paid
  shipped
  sent
  completed
}

enum CharacteristicsType {
  model
  weightKg
  shapes
  styles
  rooms
  lampType
  maxAreaM2
  mountingType
  packageSize
  frameMaterial
  frameColor
  shadeMaterials
  shadeColors
  colorTemps
  powerW
  lumens
  lampCount
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  name       String?
  phone      String?
  address    String?
  role       UserRole    @default(user)
  cart       Cart?
  favourites Favourite[]
  orders     Order[]
  addresses  Address[]
  avatarUrl  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  description     String?
  price           Float
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId      String?
  color           ProductColor?
  images          String[]
  isOnSale        Boolean       @default(false)
  discountPercent Int           @default(0)
  popularity      Int           @default(0)
  stock           Int           @default(0)
  spec            ProductSpec?
  cartItems       CartItem[]
  favourites      Favourite[]
  orderItems      OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ProductSpec {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @unique

  model          String?
  weightKg       Float?
  shapes         String[]
  styles         String[]
  rooms          String[]
  lampType       String?
  maxAreaM2      Float?
  mountingType   String?
  packageSize    String?
  frameMaterial  String?
  frameColor     String?
  shadeMaterials String[]
  shadeColors    String[]
  colorTemps     String[]
  powerW         Int?
  lumens         Int?
  lampCount      Int?
}

model Cart {
  id        String     @id @default(uuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String     @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
}

model CartItem {
  id        String  @id @default(uuid())
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int     @default(1)

  @@unique([cartId, productId])
}

model Favourite {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(uuid())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  items           OrderItem[]
  total           Float
  status          OrderStatus @default(new)
  shippingAddress String?
  phone           String?
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?
  name      String
  price     Float
  quantity  Int
}

model Address {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  label     String?
  city      String
  street    String
  house     String
  apartment String?
  zipCode   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Banner {
  id          String  @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  imageUrl    String
  action      String?
  buttonLabel String?
  isActive    Boolean @default(true)
  order       Int     @default(0)
}

model Characteristics {
  id String @id @default(uuid())

  name String
  type CharacteristicsType
}
